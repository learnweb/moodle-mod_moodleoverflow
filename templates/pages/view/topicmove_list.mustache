{{!
  @template mod_moodleoverflow/forum_list

  Moodleoverflow forum_list template.
  The purpose of this template is to render a list of forums for the view.php.

  Example context (json):
  {
  }
}}
<div class="topicmove-root table-responsive mb-3 d-none">
    <table class="table table-hover align-middle mb-0 moodleoverflowheaderlist">
        <thead class="table-light">
        <tr>
            <th class="topic small fw-semibold d-flex justify-content-between align-items-center" scope="col">
                {{! placeholder for the discussion name}}
                <span class="topicmove-origin"></span>
                <button type="button" class="btn-close" data-action="moodleoverflow/movetopic-close" aria-label="Close"></button>
            </th>
        </tr>
        </thead>
        <tbody>
        {{#destinations}}
            <tr class="discussion">
                <td class="topic starter py-2">
                    <div class="d-flex justify-content-between align-items-center gap-3">
                        <span class="fw-medium text-body">{{name}}</span>
                        <span class="btn btn-outline-secondary btn-sm d-inline-flex align-items-center gap-1"
                           data-action="moodleoverflow/movetopic-execute"
                           data-destination="{{modflowid}}"
                           data-destinationname="{{name}}">
                            {{#pix}} i/arrow-right, core, {{#str}} movetopictoforum, mod_moodleoverflow, {"forumname": {{#quote}} {{name}} {{/quote}} } {{/str}} {{/pix}}
                            <span>{{#str}} movetopictoforum, mod_moodleoverflow, {"forumname": {{#quote}} {{name}} {{/quote}} } {{/str}}</span>
                        </span>
                    </div>
                </td>
            </tr>
        {{/destinations}}
        </tbody>
    </table>
</div>