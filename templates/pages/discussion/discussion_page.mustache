{{!
  @template mod_moodleoverflow/post

  Moodleoverflow discussion page template
  This template renders the discussion page.

   Example context (json):
   {
   }
}}

<div id="moodleoverflow-posts">
    <div id="moodleoverflow-root">
        {{! This is the place for the discussion starter post}}
        {{{firstpost}}}
        <br>
        <h4>{{answeramount}}</h4>
        <div id="moodleoverflow-posts">
            {{! This is the place for the answer posts}}
            {{#answers}}{{{.}}}{{/answers}}
        </div>
    </div>
</div>