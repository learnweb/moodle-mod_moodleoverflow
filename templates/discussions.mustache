{{!
  @template mod_moodleoverflow/discussions

  Moodleoverflow discussion_list template.
  The purpose of this template is to render a list of discussions for the view.php.

  Example context (json):
  {
  }
}}

{{! There are no discussions. Print the string that specifies it. }}
{{^hasdiscussions}}
    <div class="moodleoverflowdiscussions" xmlns="http://www.w3.org/1999/xhtml">
        ( {{#str}} nodiscussions, moodleoverflow {{/str}} )
    </div>
{{/hasdiscussions}}

{{#hasdiscussions}}
{{! Paging bar if needed}}
    {{{paging_bar}}}

    {{! Top action buttons}}
    {{#startdiscussion}}
        <a href="{{{link}}}" class="btn btn-secondary m-2">{{#str}} addanewdiscussion, moodleoverflow {{/str}}</a>
    {{/startdiscussion}}
    {{#stats}}
        <a href="{{{link}}}" class="btn btn-secondary m-2">{{#str}} seeuserstats, moodleoverflow {{/str}}</a>
    {{/stats}}
    {{#markallread}}
        <a href="{{{link}}}" class="btn btn-secondary m-2">{{#str}} markallread_forum, moodleoverflow {{/str}}</a>
    {{/markallread}}

    {{! Print the table of discussions. }}
    {{#discussions}}
        {{{.}}}
    {{/discussions}}
    {{{paging_bar}}}
{{/hasdiscussions}}
