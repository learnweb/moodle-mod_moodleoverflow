{{!
    @template mod_moodleoverflow/readtracking
    Moodleoverflow read tracking template. Shows unread posts in a discussion/moodleoverflow and gives the
    option to mark all posts in a discussion/moodleoverflow as read.

    Variables required:
    * unreadlink - link to the discussion/moodleoverflow
    * unreadamount - Amount of unread posts
    * domain - if the unread posts is regarding a discussion or a moodleoverflow
    * instanceid - id of the discussion/moodleoverflow
    Example context (json):
    {
        "unreadlink":
    }
}}

<div class="mod_moodleoverflow-no-wrap unread-part d-flex align-items-baseline">
    <a class="mark-read"
       id="{{itemid}}"
       title="{{#str}}markallread, moodleoverflow{{/str}}"
       data-domain="{{domain}}"
       data-instanceid="{{instanceid}}"
       data-userid="{{userid}}">
        {{#pix}}i/delete, core {{/pix}}
    </a>
    <a class="d-inline-block mt-3" href="{{ unreadlink }}"
       title="{{#str}}amount_unread_posts_in_discussion, mod_moodleoverflow, {{unreadamount}} {{/str}}">
        <span class="fa fa-envelope icon me-0 moodleoverflow-icon-1_5x text-muted"></span>
        <span class="unread-bubble">{{ unreadamount }}</span>
    </a>
</div>
{{#js}}
    require(['mod_moodleoverflow/readtracking'], function(readtracking) {
    readtracking.init({{#quote}}{{itemid}}{{/quote}});
    });
{{/js}}